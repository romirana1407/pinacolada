# Copy to .env on the device:  cp .env.example .env  (then edit)
# .env is gitignored — keep your private values out of the repo.

# ntfy.sh topic the alert watchdog (alert-notify.py) publishes to.
# Pick something private and unguessable: anyone who knows the topic can read
# your alerts. Subscribe to it in the ntfy app to receive push notifications.
NTFY_TOPIC=pinacola-CHANGE-ME-to-something-private
