# Copy to .env on the device:  cp .env.example .env  (then edit)
# .env is gitignored — keep your private values out of the repo.

# ntfy.sh topic the alert watchdog (alert-notify.py) publishes to.
# Pick something private and unguessable: anyone who knows the topic can read
# your alerts. Subscribe to it in the ntfy app to receive push notifications.
NTFY_TOPIC=pinacola-CHANGE-ME-to-something-private

# Wireless interfaces. Defaults to wlan0 / wlan1 if unset (the Raspberry Pi case:
# built-in WiFi = AP, USB adapter = monitor). On a laptop your adapter often comes
# up with a name like wlxAABBCCDDEEFF — set it here so the AP/monitor logic finds it.
#   AP_IF  = rogue-AP / gateway / captive-portal radio
#   MON_IF = monitor / injection / audit radio  (recon, handshake, deauth, Kismet)
# Run `iw dev` to see your interface names. Full parity needs two radios; with one
# free adapter, set MON_IF to it and you get the audit half.
AP_IF=wlan0
MON_IF=wlan1
